{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "note_path": {
      "type": "string",
      "description": "Absolute path to the generated note artifact, or an empty string when no note file is produced.",
      "x-type": "artifact",
      "x-role": "note"
    },
    "provenance": {
      "type": "object",
      "properties": {
        "generated_at": {
            "type": "string"
        },
        "input_hash": {
            "type": "string"
        },
        "model": {
            "type": "string"
        }
      }
    },
    "warnings": {
        "type": "array"
    },
    "error": {
        "type": [
            "object",
            "null"
        ]
    }
  },
  "required": [
    "provenance",
    "warnings",
    "error"
  ]
}
